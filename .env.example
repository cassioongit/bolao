# ===== Bolão da Paz — variáveis de ambiente =====
# Copie este arquivo para ".env" e preencha com os dados do seu banco MySQL remoto.
# NÃO suba o .env para o Git nem deixe acessível na web.

# Ambiente (`local` grava e-mails em arquivo; `production` tenta mail() do PHP)
APP_ENV=local

# Banco de dados (MySQL remoto da sua hospedagem)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=seu_banco
DB_USER=seu_usuario
DB_PASS=sua_senha

# Aplicação
APP_NAME="Bolão da Paz"
# URL base do sistema, SEM barra no final
APP_URL=http://localhost:8050

# Regras
LOCK_MINUTES=5
DISPLAY_TZ=America/Sao_Paulo

# Cadastro
REQUIRE_EMAIL_VERIFICATION=false
FIRST_USER_IS_ADMIN=true

# E-mail (`log` salva em `nimbalyst-local/outbox`)
MAIL_DRIVER=log
# MAIL_FROM_NAME="Bolão da Paz"
# MAIL_FROM_EMAIL=nao-responda@seudominio.com.br

# Em produção deixe false (não mostra erros do PHP na tela)
SHOW_ERRORS=true
